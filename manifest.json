{
  "id": "family-contract",
  "name": "Family Contract",
  "version": "1.0.0",
  "description": "Parents create step-by-step acknowledgement contracts for kids — watch videos, agree to costs, make commitments — before a big decision like getting a pet or an instrument.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": [
    "parenting",
    "kids",
    "agreements",
    "contracts",
    "responsibility"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "contracts": {
      "kind": "party_scoped",
      "member_columns": ["child_id", "created_by"],
      "self_column": "created_by"
    }
  },
  "agreements": {
    "contracts": {
      "participant_columns": ["child_id", "created_by"],
      "agreement_columns": {
        "child_id": "child_agreed",
        "created_by": "parent_agreed"
      },
      "status_column": "status",
      "pending_value": "active",
      "locked_value": "completed",
      "updated_at_column": "updated_at"
    }
  },
  "nav": { "label": "Contracts" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "📋"
}
